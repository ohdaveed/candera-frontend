# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Etsy API
ETSY_KEYSTRING=your_etsy_api_key_here
ETSY_SHARED_SECRET=your_etsy_shared_secret_here
ETSY_SHOP_ID=your_etsy_shop_id_here
ETSY_LISTINGS_LIMIT=0
VITE_ETSY_SHOP_URL=your_shop_url_here

# Etsy OAuth 2.0 (the redirect URI must be HTTPS and match your Etsy app exactly)
# Visit /api/etsy/oauth/authorize to start the PKCE authorization-code flow.
ETSY_REDIRECT_URI=https://your-public-https-domain.example/api/etsy/oauth/callback
ETSY_SCOPES=listings_r shops_r
ETSY_REFRESH_TOKEN=

# MailChimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_list_id_here
