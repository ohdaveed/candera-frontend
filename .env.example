# Etsy API (Server-side only)
# Etsy application API keystring (Developer Portal > Your app > Keystring).
ETSY_KEYSTRING=
# Etsy application shared secret (needed for OAuth token exchange flows).
ETSY_SHARED_SECRET=
# Numeric Etsy shop ID from your Etsy shop settings/listing URLs.
ETSY_SHOP_ID=
ETSY_LISTINGS_LIMIT=50

# Frontend Configuration
# Optional if your backend requires a simple API key header.
VITE_ETSY_BACKEND_API_KEY=
# Optional fallback Etsy shop URL when listing URL is missing.
VITE_ETSY_SHOP_URL=https://www.etsy.com/shop/CanderaCandles

# MailChimp Configuration
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=
