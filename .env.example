VITE_ETSY_BACKEND_URL=http://localhost:3000
VITE_ETSY_PRODUCTS_ENDPOINT=/api/etsy/listings
# Optional if your backend requires a simple API key header.
VITE_ETSY_BACKEND_API_KEY=
# Optional fallback Etsy shop URL when listing URL is missing.
VITE_ETSY_SHOP_URL=https://www.etsy.com/shop/CanderaCandles

# Legacy single URL fallback.
# VITE_PRODUCTS_API_URL=http://localhost:3000/api/etsy/listings

# Node server settings (server-side only).
PORT=3000
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=
ETSY_SHOP_ID=
